# Dependencies
node_modules/

# Secrets and local environment (never commit — contains the auth password and
# Brevo API key). Use .env.example as the template.
.env
.env.*
!.env.example

# Runtime state: per-account notification settings, written at runtime and
# holding real account names. Not source.
data/

# Apache gateway secrets — a real .htaccess holds LD_HTACCESS_SECRET and .htpasswd
# holds credentials. Never commit them; .htaccess.example is the tracked template.
.htaccess
.htpasswd
!.htaccess.example

# Logs and OS cruft
*.log
.DS_Store

# --- Auth (BASIC AUTH) ---
# Required. The dashboard exposes server logs; never run without auth.
# The server REFUSES to boot if LD_PASS is unset or shorter than 8 chars,
# unless LD_ALLOW_NO_AUTH=1 is set (see below).
LD_USER=admin
LD_PASS=changeme-use-a-long-random-string
# Escape hatch: set to 1 ONLY to run without authentication on purpose
# (e.g. bound to loopback behind a trusted reverse proxy, or local testing).
# LD_ALLOW_NO_AUTH=0

# --- Network ---
LD_HOST=0.0.0.0
LD_PORT=3212

# --- Discovery cache ---
# TTL of the cached log-path discovery (ms). 5-10 min recommended.
LD_CACHE_TTL=480000
# Max recursive depth when scanning /home/USER for *.log files.
LD_MAX_DEPTH=12
# Skip these directory name fragments during traversal (comma separated).
LD_SKIP_DIRS=node_modules,.git,backup,backups,cpmove,tmp,.cpanel,mail,logs/.spamassassin,.Trash,.npm,wp-admin,wp-includes
# Pattern(s) matched against filenames (case-insensitive). Default: log files.
LD_LOG_GLOB=*.log
LD_LOG_EXTRA=error_log
# Hard cap on number of log files returned per account (safety).
LD_MAX_LOGS_PER_ACCOUNT=5000

# --- Streaming ---
# Bytes read backwards from EOF for the initial "newest-first" view.
LD_INITIAL_TAIL_BYTES=262144
# Max number of initial lines sent to a viewer.
LD_INITIAL_MAX_LINES=500
# Tail polling interval (ms) for live mode. Polls file size only.
LD_TAIL_POLL_MS=1000
# Max live listeners per file before forcing shared-single-watcher semantics.
LD_MAX_LIVE_LISTENERS=64
# Hard cap on bytes scanned per file during a search request (0 = unlimited).
LD_SEARCH_MAX_BYTES_PER_FILE=268435456

# --- Security ---
# Top-level home root. All filesystem access is constrained under this.
LD_HOME_ROOT=/home
# --- Email notifications (Brevo) ---
# MASTER ARM SWITCH. While 0, the notifier still watches logs, classifies and
# buffers entries, and logs an hourly "would have sent" summary — but NO email
# ever leaves the box. Set to 1 ONLY when you are ready to send for real.
# The server refuses to boot with this set to 1 while the API key or sender
# address is missing, so it can never look armed while being unable to send.
LD_NOTIFY_ENABLED=0
# Brevo transactional-email API key (Brevo dashboard -> SMTP & API -> API keys).
LD_BREVO_API_KEY=
# Sender address. MUST be a verified sender/domain in Brevo or it will reject.
LD_BREVO_SENDER_EMAIL=
LD_BREVO_SENDER_NAME=Log Dashboard
# Digest cadence is now chosen PER ACCOUNT in the UI (every hour / 3h / 6h / 12h /
# daily / weekly / monthly). This value is the BASE TICK — how often the server
# checks which accounts are due — and the DEFAULT an account inherits until one is
# picked (if it matches an offered period, e.g. 21600000 → "Every 6 hours", that
# becomes the default; otherwise the default is hourly). 3600000 = hourly, the
# shortest offered cadence. Minimum 60000. Lower it only to test cadences faster.
LD_NOTIFY_INTERVAL_MS=3600000
# How often watchers are reconciled with saved settings (ms). Picks up log files
# that did not exist when the settings were saved.
LD_NOTIFY_RESYNC_MS=300000
# Where per-account notification settings are stored. Must be writable — under
# systemd it must also appear in ReadWritePaths= in the unit file.
# LD_NOTIFY_DATA_DIR=/root/log-dashboard/data
# Memory guards for the digest buffer.
# Max distinct grouped messages held per account between two digests.
LD_NOTIFY_MAX_GROUPS=200
# Max characters of a log entry kept as the sample shown in the email.
LD_NOTIFY_MAX_SAMPLE=2000
# Max log files one account may select for watching.
LD_NOTIFY_MAX_FILES=200
# Test email: how many recent entries to show per selected severity.
LD_NOTIFY_TEST_SAMPLE=5
# Scan budget for finding those entries (bytes). A severity filter forces a
# backwards scan, so this is capped per file and overall.
LD_NOTIFY_SAMPLE_MAX_BYTES_PER_FILE=4194304
LD_NOTIFY_SAMPLE_MAX_BYTES_TOTAL=33554432
